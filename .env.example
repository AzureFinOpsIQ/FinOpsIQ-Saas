# Azure subscription & authentication (service principal)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=

# Phase A storage provider (file or cosmos)
STORAGE_PROVIDER=file
STORAGE_DATA_DIR=data
DEFAULT_TENANT_ID=
DEFAULT_SUBSCRIPTION_ID=

# Optional Cosmos DB for NoSQL + Blob raw payload storage
COSMOS_ENDPOINT=
COSMOS_DATABASE=azure-cost-advisor
# Local-only fallback. Production uses managed identity with Cosmos data-plane RBAC.
COSMOS_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=finops-raw

# Phase B interactive Microsoft Entra authentication
AUTH_MODE=legacy
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
COLLECTION_ENTRA_CLIENT_ID=
# Set automatically by AKS Workload Identity in production.
AZURE_FEDERATED_TOKEN_FILE=
ENTRA_AUTHORITY=https://login.microsoftonline.com/common
ENTRA_REDIRECT_URI=http://localhost:8501
ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:8501

# Phase E API and primary Next.js frontend
API_HOST=0.0.0.0
API_PORT=8000
API_SESSION_SECRET=replace-with-at-least-32-random-bytes
API_CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_SESSION_COOKIE_SECURE=false

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Phase D search provider (azure_ai_search or faiss)
SEARCH_PROVIDER=azure_ai_search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=finops-knowledge
AZURE_SEARCH_SEMANTIC_CONFIG=finops-semantic
AZURE_SEARCH_VECTOR_DIMENSIONS=1536

# Application paths (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EMBEDDINGS_DIR=data/embeddings

# Cost collection
COST_LOOKBACK_DAYS=30
ANOMALY_ZSCORE_THRESHOLD=2.5
WASTE_IDLE_CPU_THRESHOLD=5.0
WASTE_MIN_MONTHLY_COST=10.0
COLLECTION_INTERVAL_MINUTES=1440
COLLECTION_MODE=auto
COLLECTION_SCHEDULER_ENABLED=false

# Streamlit
STREAMLIT_SERVER_PORT=8501
